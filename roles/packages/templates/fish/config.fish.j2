#!/usr/bin/fish

{{ ansible_managed | comment }}

# disable git info from promt when tmux is running
function __fish_git_prompt_ready
    not set --query TMUX
end

# general
set -g fish_key_bindings fish_vi_key_bindings
set -U fish_greeting

# Force autopair to load explicitly inside Vi's insert mode
function fish_user_key_bindings
    if functions -q _autopair_fish_key_bindings
        # Bind specifically to Vi insert mode
        _autopair_fish_key_bindings -M insert
    end
end

# prompt
set -U pure_enable_git false
set -U pure_reverse_prompt_symbol_in_vimode false
set -U pure_show_system_time true

# hotkeys
bind -M insert \cf accept-autosuggestion

# enable nix
if test -e "{{ packages_nix_daemon }}.fish"
    source "{{ packages_nix_daemon }}.fish"
end
